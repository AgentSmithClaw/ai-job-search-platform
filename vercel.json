{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app/main.py" },
    { "src": "/assets/(.*)", "dest": "frontend/dist/assets/$1" },
    { "src": "/favicon.svg", "dest": "frontend/dist/favicon.svg" },
    { "src": "/icons.svg", "dest": "frontend/dist/icons.svg" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html", "status": 200 }
  ]
}
