{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app/main.py" },
    { "src": "/assets/(.*)", "dest": "public/assets/$1" },
    { "src": "/favicon.svg", "dest": "public/favicon.svg" },
    { "src": "/icons.svg", "dest": "public/icons.svg" },
    { "src": "/", "dest": "public/index.html" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
