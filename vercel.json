{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "app/main.py" },
    { "source": "/assets/(.*)", "destination": "public/assets/$1" },
    { "source": "/favicon.svg", "destination": "public/favicon.svg" },
    { "source": "/icons.svg", "destination": "public/icons.svg" },
    { "source": "/(.*)", "destination": "public/$1" }
  ]
}
