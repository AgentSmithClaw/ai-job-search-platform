{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app/main.py" },
    { "src": "/(.*)", "dest": "app/main.py" }
  ],
  "buildCommand": "cd frontend && npm install && npm run build",
  "installCommand": "pip install -r requirements.txt"
}
